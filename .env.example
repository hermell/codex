# Telegram Bot 토큰 (@BotFather에서 발급)
TELEGRAM_BOT_TOKEN=123456789:ABCDEF...

# 수신할 채팅 ID (개인: 숫자, 그룹: -100...)
TELEGRAM_CHAT_ID=-1001234567890

# 콤마(,)로 구분된 RSS URL 목록
RSS_FEEDS=https://news.google.com/rss?hl=ko&gl=KR&ceid=KR:ko,https://www.yna.co.kr/rss/all.xml

# 전송 시각 (24시간제)
SEND_HOUR=7
SEND_MINUTE=30

# 하루에 보낼 핵심 뉴스 개수
TOP_N=8

# 요약 문장 개수
SUMMARY_SENTENCES=2

# HTTP 요청 타임아웃(초)
REQUEST_TIMEOUT=12
